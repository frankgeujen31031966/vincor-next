# ─── Contact Formulier (Resend.com) ───
# 1. Maak een account aan op https://resend.com (gratis tot 3000 emails/maand)
# 2. Genereer een API key op https://resend.com/api-keys
# 3. Verifieer je domein op https://resend.com/domains (vincorscan.nl)
# 4. Vul onderstaande waarden in en hernoem dit bestand naar .env.local

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL_TO=info@vincorscan.nl
CONTACT_EMAIL_FROM=Vincor Website <noreply@vincorscan.nl>

# ─── CMS Admin (/admin) ───
# Wachtwoord voor toegang tot het CMS. Zonder deze waarde is /admin geblokkeerd.
ADMIN_USER=admin
ADMIN_PASSWORD=kies-een-sterk-wachtwoord
